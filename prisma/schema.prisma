datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Status {
  active
  inactive
  pending
  disabled
}

enum OrderStatus {
  pending
  confirmed
  processing
  shipped
  delivered
  cancelled
  refunded
  failed
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
  partially_refunded
}

model PaymentHistory {
  id        Int      @id @default(autoincrement())
  paymentId Int
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  action    String   @db.VarChar(50) // 'authorize', 'capture', 'refund', 'void'
  amount    Float
  currency  String   @default("USD") @db.VarChar(10)
  notes     String?
  createdAt DateTime @default(now())

  @@index([paymentId])
  @@index([createdAt])
}

model GiftCard {
  id             Int       @id @default(autoincrement())
  code           String    @unique @db.VarChar(50)
  initialAmount  Float
  currentBalance Float
  currency       String    @default("USD") @db.VarChar(10)
  isActive       Boolean   @default(true)
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  transactions GiftCardTransaction[]

  @@index([code])
  @@index([isActive])
  @@index([expiresAt])
}

model GiftCardTransaction {
  id         Int      @id @default(autoincrement())
  giftCardId Int
  giftCard   GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)
  orderId    Int?
  order      Order?   @relation(fields: [orderId], references: [id])
  amount     Float
  type       String   @db.VarChar(20) // 'purchase', 'redemption', 'refund'
  notes      String?
  createdAt  DateTime @default(now())

  @@index([giftCardId])
  @@index([orderId])
  @@index([createdAt])
}

// schema.prisma
model Prescription {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  imageUrl    String
  fileName    String
  fileSize    Int
  isValidated Boolean   @default(false)
  validatedBy Int?
  validatedAt DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime? // Add this for soft delete instead of isDeleted

  orderPrescriptions OrderPrescription[]

  @@index([userId])
  @@index([isValidated])
  @@index([createdAt])
  @@index([deletedAt]) // Add index for soft delete queries
}

model OrderPrescription {
  id             Int          @id @default(autoincrement())
  orderId        Int
  prescriptionId Int
  order          Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([orderId, prescriptionId])
  @@index([orderId])
  @@index([prescriptionId])
}

model Payment {
  id      Int   @id @default(autoincrement())
  orderId Int
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // TEMPORARY: Make this optional first
  paymentMethodId Int?
  paymentMethod   PaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)

  // Add this relation field
  paymentHistories PaymentHistory[]

  // ... rest of your Payment fields
  paymentStatus   PaymentStatus @default(pending)
  amount          Float
  currency        String        @default("USD") @db.VarChar(10)
  transactionId   String?       @db.VarChar(100)
  paymentGateway  String?       @db.VarChar(50)
  gatewayResponse Json?
  lastFourDigits  String?       @db.VarChar(4)
  cardBrand       String?       @db.VarChar(50)
  paidAt          DateTime?
  failedAt        DateTime?
  refundedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([orderId]) // Add this for one-to-one relation
  @@index([orderId])
  @@index([paymentMethodId])
  @@index([transactionId])
  @@index([paymentStatus])
  @@index([createdAt])
}

enum CouponType {
  Percentage
  FixedAmount
}

enum CouponAppliesTo {
  all
  categories
  products
  brands
}

enum CouponStatus {
  Active
  Inactive
  Expired
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique @db.VarChar(100)
  permissions Permission[]
  users       User[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(100)
  menuName  String   @db.VarChar(100)
  roles     Role[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Credential {
  id            Int            @id @default(autoincrement())
  email         String         @unique @db.VarChar(191)
  password      String         @db.VarChar(255)
  lastLogin     DateTime?
  isDeleted     Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        Int            @unique
}

model RefreshToken {
  id        String     @id @default(uuid())
  user      Credential @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  revoked   Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([userId])
}

// --- New Model: UserAddress ---
model UserAddress {
  id Int @id @default(autoincrement())

  // Link back to the User
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  // Address Details
  name          String  @db.VarChar(100) // E.g., "Home", "Work", or Recipient Name
  streetAddress String  @db.VarChar(255)
  city          String  @db.VarChar(100)
  state         String? @db.VarChar(50)
  zipCode       String? @db.VarChar(20)

  // Management Fields
  isDefault Boolean @default(false) // Flag for the user's preferred/primary address

  // Audit Fields (Aligned with User model structure)
  isActive  Boolean  @default(true)
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model User {
  id            Int            @id @default(autoincrement())
  firstName     String         @db.VarChar(100)
  middleName    String?        @db.VarChar(100)
  lastName      String         @db.VarChar(100)
  email         String         @unique @db.VarChar(191)
  phoneNumber   String         @db.VarChar(20)
  prescriptions Prescription[]

  // Address relationship
  addresses UserAddress[]

  profilePicture String? @db.VarChar(500)
  status         Status  @default(pending)

  // Role and Credential relations
  role       Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId     Int
  credential Credential?

  // Blog interactions
  blogPostLikes  BlogPostLike[] // NEW: Blog posts liked by user
  blogPostShares BlogPostShare[] // NEW: Blog posts shared by user

  // Audit Fields
  isDeleted Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Other relations
  orders       Order[]
  cart         Cart?
  couponUsage  CouponUsage[]
  queuedEmails QueuedEmail[]

  @@index([roleId])
  @@index([email])
  @@index([isActive])
}

model Brand {
  id          Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(100)
  logo        String?   @db.VarChar(500)
  website     String?   @db.VarChar(255)
  description String?   @db.Text
  isDeleted   Boolean   @default(false)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  metaTitle       String? @db.VarChar(150)
  metaDescription String? @db.Text
  slug            String? @unique @db.VarChar(100)
}

model Category {
  id           Int      @id @default(autoincrement())
  name         String   @unique @db.VarChar(100)
  slug         String   @unique @db.VarChar(100)
  catLogo      String?  @db.VarChar(500)
  catColor     String?  @db.VarChar(50)
  description  String?  @db.Text
  imageAlt     String?
  bannerAlt    String?
  logoAlt      String?
  isDeleted    Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  displayOrder Int?     @default(0)
  image        String?  @db.VarChar(500)
  banner       String?  @db.VarChar(500)

  products Product[]

  metaTitle       String?            @db.VarChar(150)
  metaDescription String?            @db.Text
  parentId        Int?
  parent          Category?          @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children        Category[]         @relation("CategoryHierarchy")
  blogPosts       BlogPostCategory[]

  @@index([parentId])
}

model Product {
  id                    Int              @id @default(autoincrement())
  sku                   String           @unique @db.VarChar(100)
  name                  String           @db.VarChar(200)
  slug                  String           @unique @db.VarChar(150)
  description           String?          @db.Text
  shortDescription      String?          @db.VarChar(300)
  metaTitle             String?          @db.VarChar(150)
  metaDescription       String?          @db.Text
  canonicalUrl          String?          @db.VarChar(255)
  ogImage               String?          @db.VarChar(500)
  structuredData        Json?
  seoKeywords           String?          @db.Text
  searchableText        String?          @db.Text
  altText               Json?
  composition           String?          @db.Text
  benefits              Json?
  usageInstructions     String?          @db.Text
  faqs                  Json?
  ingredients           Json?
  specifications        Json?
  strengths             Json
  forms                 Json
  images                Json
  tags                  Json
  symptoms              Json
  price                 Float
  mrp                   Float
  discount_percent      Int              @default(0)
  prescription_required Boolean          @default(false)
  rating                Float            @default(0.0)
  reviews               Int              @default(0)
  views                 Int              @default(0)
  isFeatured            Boolean          @default(false)
  isTrending            Boolean          @default(false)
  clickThroughRate      Float?           @default(0.0)
  searchImpressions     Int?             @default(0)
  lastSeoUpdate         DateTime?
  
  // 🆕 NEW FIELDS ADDED
  country               String           @db.VarChar(50) @default("Global")
  stock                 Int              @default(0)
  min_order_quantity    Int              @default(1)
  max_order_quantity    Int              @default(10)
  weight                Float?           @default(0.0)
  dimensions            String?          @db.VarChar(100)
  
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  isDeleted             Boolean          @default(false)
  isActive              Boolean          @default(true)
  brand_id              Int
  brand                 Brand            @relation(fields: [brand_id], references: [id], onDelete: Cascade)
  category_id           Int
  category              Category         @relation(fields: [category_id], references: [id], onDelete: Cascade)
  variants              ProductVariant[]
  seoAudits             SeoAudit[]
  searchKeywords        SearchKeyword[]
  orderItems            OrderItem[]
  cartItems             CartItem[]

  @@index([sku])
  @@index([slug])
  @@index([brand_id])
  @@index([category_id])
  @@index([isActive])
  @@index([isDeleted])
  @@index([isFeatured])
  @@index([isTrending])
  @@index([price])
  @@index([rating])
  @@index([createdAt])
  @@index([country])        // 🆕 NEW INDEX
  @@index([stock])          // 🆕 NEW INDEX
}

model ProductVariant {
  id         Int             @id @default(autoincrement())
  product_id Int
  country    String          @db.VarChar(50)
  shipping   String          @db.VarChar(50)
  currency   String          @db.VarChar(10)
  product    Product         @relation(fields: [product_id], references: [id], onDelete: Cascade)
  options    VariantOption[]
  isActive   Boolean         @default(true)
  isDeleted  Boolean         @default(false)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([product_id, country, shipping])
  @@index([product_id])
}

model VariantOption {
  id         Int            @id @default(autoincrement())
  variant_id Int
  label      String         @db.VarChar(100)
  price      Float
  mrp        Float
  stock      Int
  sku        String?        @db.VarChar(100)
  weight     Float?
  dimensions Json?          // ✅ Already exists in your schema
  isActive   Boolean        @default(true)
  isDeleted  Boolean        @default(false)
  variant    ProductVariant @relation(fields: [variant_id], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  cartItems  CartItem[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([variant_id])
  @@index([sku])
}

model SeoAudit {
  id              Int      @id @default(autoincrement())
  productId       Int?
  product         Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  url             String   @db.VarChar(255)
  auditDate       DateTime @default(now())
  seoScore        Int
  issues          Json?
  recommendations Json?
  createdAt       DateTime @default(now())

  @@index([productId])
  @@index([auditDate])
}

model SearchKeyword {
  id         Int      @id @default(autoincrement())
  keyword    String   @db.VarChar(150)
  productId  Int?
  product    Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  rank       Int?
  volume     Int?
  difficulty Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([keyword, productId])
  @@index([keyword])
  @@index([productId])
  @@index([rank])
}

model Order {
  id          Int    @id @default(autoincrement())
  orderNumber String @unique @db.VarChar(50)
  userId      Int
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Add these relation fields
  payment              Payment? // One-to-one with Payment
  giftCardTransactions GiftCardTransaction[] // Relation with GiftCardTransaction
  prescriptions        OrderPrescription[] // Relation through join table

  // ... rest of your Order fields
  status            OrderStatus     @default(pending)
  paymentStatus     PaymentStatus   @default(pending)
  
  // TEMPORARY: Make this optional first, we'll populate data then make required
  paymentMethodCode String?         @db.VarChar(50)
  
  currency          String          @default("USD") @db.VarChar(10)
  subtotal          Float
  taxAmount         Float           @default(0)
  shippingAmount    Float           @default(0)
  discountAmount    Float           @default(0)
  totalAmount       Float
  couponId          Int?
  coupon            Coupon?         @relation(fields: [couponId], references: [id])
  couponCode        String?         @db.VarChar(50)
  couponDiscount    Float           @default(0)
  shippingAddress   Json
  billingAddress    Json
  contactEmail      String          @db.VarChar(191)
  contactPhone      String          @db.VarChar(20)
  shippingMethod    String?         @db.VarChar(50)
  trackingNumber    String?         @db.VarChar(100)
  estimatedDelivery DateTime?
  orderDate         DateTime        @default(now())
  paidAt            DateTime?
  shippedAt         DateTime?
  deliveredAt       DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  orderItems        OrderItem[]
  orderHistory      OrderHistory[]
  couponUsage       CouponUsage[]
  queuedEmails      QueuedEmail[]
  shippingOption    ShippingOption? @relation(fields: [shippingOptionId], references: [id])
  shippingOptionId  Int?

  @@index([userId])
  @@index([orderNumber])
  @@index([status])
  @@index([paymentStatus])
  @@index([paymentMethodCode])
  @@index([orderDate])
  @@index([createdAt])
}

model OrderItem {
  id              Int            @id @default(autoincrement())
  orderId         Int
  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       Int
  product         Product        @relation(fields: [productId], references: [id])
  variantOptionId Int?
  variantOption   VariantOption? @relation(fields: [variantOptionId], references: [id])

  productName  String  @db.VarChar(200)
  productSku   String  @db.VarChar(100)
  variantLabel String? @db.VarChar(100)

  unitPrice      Float
  quantity       Int
  discountAmount Float @default(0)
  totalPrice     Float

  productSnapshot Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
}

model OrderHistory {
  id      Int   @id @default(autoincrement())
  orderId Int
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  oldStatus OrderStatus?
  newStatus OrderStatus
  notes     String?      @db.Text
  createdBy Int?
  createdAt DateTime     @default(now())

  @@index([orderId])
  @@index([createdAt])
}

model Cart {
  id        Int        @id @default(autoincrement())
  userId    Int        @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id              Int            @id @default(autoincrement())
  cartId          Int
  cart            Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId       Int
  product         Product        @relation(fields: [productId], references: [id])
  variantOptionId Int? // Can be null for products without variants
  variantOption   VariantOption? @relation(fields: [variantOptionId], references: [id])
  quantity        Int            @default(1)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Use a custom unique constraint that handles null values
  @@unique([cartId, productId, variantOptionId])
  @@index([cartId])
  @@index([productId])
  // Add this to handle the case where variantOptionId is null
  @@map("cart_items")
}

model Coupon {
  id            Int             @id @default(autoincrement())
  code          String          @unique @db.VarChar(50)
  type          CouponType
  value         Float
  freeShipping  Boolean         @default(false)
  status        CouponStatus    @default(Active)
  minPurchase   Float           @default(0)
  usageLimit    Int?
  usageCount    Int             @default(0)
  perUserLimit  Int             @default(1)
  startDate     DateTime?
  endDate       DateTime?
  appliesTo     CouponAppliesTo @default(all)
  applicableIds Json?
  isPublic      Boolean         @default(true) // NEW: Public/Private flag
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  isDeleted     Boolean         @default(false)

  orders      Order[]
  couponUsage CouponUsage[]

  @@index([code])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@index([isPublic]) // NEW: Index for public coupons
}

model CouponUsage {
  id       Int      @id @default(autoincrement())
  couponId Int
  coupon   Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId   Int
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId  Int
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  usedAt   DateTime @default(now())

  @@unique([couponId, orderId])
  @@index([userId])
  @@index([orderId])
}


model AboutUs {
  id          Int      @id @default(autoincrement())
  title       String
  subtitle    String?
  description String   @db.Text
  mission     String   @db.Text
  vision      String?  @db.Text
  values      Json?    // Array of { title: string, description: string }
  image       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isDeleted   Boolean  @default(false)

  @@index([isActive])
  @@index([isDeleted])
}

enum EmailTemplateStatus {
  active
  inactive
}


enum AutomationStatus {
  active
  inactive
  processing
  paused
}

enum QueuedEmailStatus {
  pending
  processing
  sent
  failed
  cancelled
}

enum EmailType {
  TRANSACTIONAL
  MARKETING
  NOTIFICATION
  SYSTEM
}

model EmailTemplate {
  id          Int        @id @default(autoincrement())
  name        String     @db.VarChar(255)
  subject     String     @db.VarChar(500)
  body        String     @db.Text
  type        EmailType  @default(TRANSACTIONAL)
  category    String?    @db.VarChar(100)
  description String?    @db.Text
  variables   String?    @db.Text
  status      EmailTemplateStatus @default(active)
  isSystem    Boolean    @default(false)
  isDeleted   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  automationRules AutomationRule[]
  queuedEmails    QueuedEmail[]
  emailLogs       EmailLog[]

  @@map("email_templates")
}

model AutomationRule {
  id          Int               @id @default(autoincrement())
  name        String            @db.VarChar(255)
  description String?           @db.Text
  trigger     String            @db.VarChar(100) // Changed from AutomationTrigger to String
  conditions  String?           @db.Text
  delayHours  Int               @default(0)
  templateId  Int
  status      AutomationStatus  @default(active)
  priority    Int               @default(1)
  maxAttempts Int               @default(3)
  isDeleted   Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Relations
  emailLogs    EmailLog[]
  template     EmailTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  queuedEmails QueuedEmail[]

  @@map("automation_rules")
}

model QueuedEmail {
  id             Int               @id @default(autoincrement())
  ruleId         Int?
  templateId     Int
  userId         Int?
  orderId        Int?
  recipientEmail String            @db.VarChar(255)
  subject        String            @db.VarChar(500)
  body           String            @db.Text
  variables      String?           @db.Text // JSON of variables used
  scheduledFor   DateTime
  status         QueuedEmailStatus @default(pending)
  attempts       Int               @default(0)
  maxAttempts    Int               @default(3)
  sentAt         DateTime?
  error          String?           @db.Text
  isDeleted      Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  // Relations
  template EmailTemplate   @relation(fields: [templateId], references: [id])
  rule     AutomationRule? @relation(fields: [ruleId], references: [id])
  user     User?           @relation(fields: [userId], references: [id])
  order    Order?          @relation(fields: [orderId], references: [id])

  @@index([status, scheduledFor])
  @@index([recipientEmail])
  @@map("queued_emails")
}

model EmailLog {
  id         Int       @id @default(autoincrement())
  templateId Int
  ruleId     Int?
  recipient  String    @db.VarChar(255)
  subject    String    @db.VarChar(500)
  body       String?   @db.Text // 🆕 ADD THIS FIELD
  status     String    @db.VarChar(50)
  messageId  String?   @db.VarChar(255)
  error      String?   @db.Text
  metadata   Json?     // 🆕 ADD THIS FIELD
  opened     Boolean   @default(false)
  openedAt   DateTime?
  clicked    Boolean   @default(false)
  clickedAt  DateTime?
  createdAt  DateTime  @default(now())

  template EmailTemplate   @relation(fields: [templateId], references: [id])
  rule     AutomationRule? @relation(fields: [ruleId], references: [id])

  @@index([recipient])
  @@index([createdAt])
  @@map("email_logs")
}

enum BlogPostStatus {
  draft
  published
  archived
}

enum HomepageSectionType {
  TRUST_BADGES
  PROMO_BANNER
  CATEGORY_GRID
  CATEGORY_CAROUSEL
  PROMO_CARDS
  PROMO_GRID
  FEATURED_PRODUCTS
  TESTIMONIALS
  BRAND_CAROUSEL
  BLOG
  FAQ
  VIDEO
  CALL_TO_ACTION
  FEATURE_CARDS
  KEY_METRICS
  IMAGE_GALLERY
  GRID
  NEWSLETTER_SIGNUP
}

model BlogPost {
  id            Int            @id @default(autoincrement())
  title         String         @db.VarChar(200)
  slug          String         @unique @db.VarChar(200)
  author        String         @db.VarChar(100)
  status        BlogPostStatus @default(draft)
  publishDate   DateTime?
  featuredImage String?        @db.VarChar(500)
  images        Json?
  content       String         @db.Text
  excerpt       String?        @db.VarChar(300)

  // SEO fields
  metaTitle       String? @db.VarChar(150)
  metaDescription String? @db.Text
  canonicalUrl    String? @db.VarChar(255)
  ogImage         String? @db.VarChar(500)
  structuredData  Json?
  seoKeywords     String? @db.Text

  // Analytics
  views  Int @default(0)
  likes  Int @default(0)
  shares Int @default(0)

  // Blog interactions
  blogPostLikes  BlogPostLike[] // NEW: Likes for this blog post
  blogPostShares BlogPostShare[] // NEW: Shares for this blog post

  isDeleted Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories BlogPostCategory[]

  @@index([slug])
  @@index([status])
  @@index([publishDate])
  @@index([isActive])
}

model BlogPostLike {
  id         Int      @id @default(autoincrement())
