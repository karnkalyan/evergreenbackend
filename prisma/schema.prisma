model Media {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // File Information
  fileName     String // Stored filename
  originalName String // Original filename
  filePath     String // Relative path from uploads directory
  mimeType     String // File MIME type
  size         Int // File size in bytes
  extension    String // File extension

  // File Metadata
  width    Int? // For images only
  height   Int? // For images only
  duration Int? // For videos/audio only (in seconds)

  // Media Information
  title       String? // Optional title
  altText     String? // SEO alt text
  description String? // Optional description
  caption     String? // Optional caption

  // Categorization
  type     MediaType // IMAGE, DOCUMENT, VIDEO, AUDIO, OTHER
  category String? // Optional category for grouping

  // Usage Tracking
  isUsed Boolean @default(false) // Whether media is used anywhere

  // User who uploaded the file
  uploadedBy Int? // User ID (if authenticated)

  // Indexes
  @@index([type])
  @@index([category])
  @@index([isUsed])
  @@index([uploadedBy])
  @@index([createdAt])
}

enum MediaType {
  IMAGE
  DOCUMENT
  VIDEO
  AUDIO
  OTHER
}

